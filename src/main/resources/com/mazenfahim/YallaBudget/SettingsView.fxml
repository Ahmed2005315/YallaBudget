<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.mazenfahim.YallaBudget.Controller.SettingController"
            stylesheets="@css/home.css"
            prefHeight="680.0" prefWidth="900.0"
            styleClass="app-root">
    <VBox spacing="18.0" AnchorPane.leftAnchor="240.0" AnchorPane.rightAnchor="240.0" AnchorPane.topAnchor="80.0">
        <padding>
            <Insets top="30.0" right="30.0" bottom="30.0" left="30.0" />
        </padding>
        <Label text="Settings" styleClass="app-title" />
        <Label text="Change PIN" styleClass="app-subtitle" />
        <PasswordField fx:id="oldPinInput" promptText="Old PIN" />
        <PasswordField fx:id="newPinInput" promptText="New PIN" />
        <PasswordField fx:id="confirmNewPinInput" promptText="Confirm new PIN" />
        <Label fx:id="errorLabel" styleClass="error-label" />
        <Button text="Change PIN" maxWidth="Infinity" onAction="#onChangePinClicked" styleClass="primary-button" />
        <Button text="Reset Budget Cycle" maxWidth="Infinity" onAction="#onResetCycleClicked" styleClass="danger-button" />
        <HBox alignment="CENTER_RIGHT">
            <Button text="Back" onAction="#onBackClicked" styleClass="secondary-button" />
        </HBox>
    </VBox>
</AnchorPane>
