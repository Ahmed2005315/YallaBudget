<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.mazenfahim.YallaBudget.Controller.HistoryController"
            stylesheets="@css/home.css"
            prefHeight="680.0" prefWidth="900.0"
            styleClass="app-root">
    <VBox spacing="18.0" AnchorPane.leftAnchor="40.0" AnchorPane.rightAnchor="40.0" AnchorPane.topAnchor="30.0" AnchorPane.bottomAnchor="30.0">
        <HBox alignment="CENTER_LEFT" spacing="16.0">
            <Label text="History" styleClass="app-title" HBox.hgrow="ALWAYS" />
            <Button text="Back" onAction="#onBackClicked" styleClass="secondary-button" />
        </HBox>
        <HBox spacing="12.0" alignment="CENTER_LEFT">
            <ComboBox fx:id="categoryFilterComboBox" promptText="Category" onAction="#onFilterChanged" />
            <DatePicker fx:id="fromDatePicker" promptText="From" onAction="#onFilterChanged" />
            <DatePicker fx:id="toDatePicker" promptText="To" onAction="#onFilterChanged" />
            <Button fx:id="deleteButton" text="Delete Selected" onAction="#onDeleteExpenseClicked" styleClass="danger-button" />
        </HBox>
        <Label fx:id="messageLabel" styleClass="warning-label" />
        <TableView fx:id="expenseTableView" VBox.vgrow="ALWAYS" />
    </VBox>
</AnchorPane>
